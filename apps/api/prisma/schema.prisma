// Estrategor — schema PostgreSQL (Semana 1).
// Fonte única do estado da aplicação (spec §8: nada de localStorage no front-end).
// Os enums espelham packages/shared/src/enums.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────
enum Role {
  ADMIN
  PADRAO
}

enum ProjectState {
  A0
  A1
  A2
  A3
  A4
  B0
  B1
  B2
}

enum ChecklistStatus {
  EM_FALTA
  RECEBIDO
  EM_REVISAO
}

enum DocConfidence {
  ALTA
  BAIXA
}

enum ReminderStatus {
  AGENDADO
  ENVIADO
  ESCALADO
  FECHADO
}

enum CollectionLinkStatus {
  ATIVO
  USADO
  EXPIRADO
}

// ─── Épico A — Acesso e Utilizadores ─────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  fullName     String   @map("full_name")
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(PADRAO)
  initials     String
  color        String   @default("green")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  responsibleFor   ProjectResponsible[]
  responsibleItems ChecklistItem[]      @relation("ChecklistResponsible")
  stateTransitions StateTransition[]
  createdLinks     CollectionLink[]
  assignedTasks    Task[]
  diagnostics      Diagnostic[]
  activities       ActivityLog[]

  @@map("users")
}

// ─── Clientes e Programas ────────────────────────────────────────────────
model Client {
  id                String    @id @default(cuid())
  name              String
  nif               String?
  sector            String?
  workdriveFolderId String?   @map("workdrive_folder_id")
  crmDealId         String?   @unique @map("crm_deal_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  projects          Project[]

  @@map("clients")
}

model Program {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  projects    Project[]
  diagnostics Diagnostic[]
  meritGrids  MeritGrid[]
  avisos      Aviso[]

  @@map("programs")
}

// ─── Épico B — Base da Aplicação ─────────────────────────────────────────
model Project {
  id              String       @id @default(cuid())
  code            String       @unique
  title           String
  clientId        String       @map("client_id")
  programId       String       @map("program_id")
  state           ProjectState @default(A0)
  investmentTotal Decimal?     @map("investment_total") @db.Decimal(14, 2)
  incentiveValue  Decimal?     @map("incentive_value") @db.Decimal(14, 2)
  nextAction      String?      @map("next_action")
  progress        Int          @default(0)
  crmDealId       String?      @unique @map("crm_deal_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  client           Client               @relation(fields: [clientId], references: [id])
  program          Program              @relation(fields: [programId], references: [id])
  responsibles     ProjectResponsible[]
  stateTransitions StateTransition[]
  checklistItems   ChecklistItem[]
  documents        Document[]
  collectionLinks  CollectionLink[]
  reminders        Reminder[]
  deadlines        Deadline[]
  tasks            Task[]
  diagnostics      Diagnostic[]
  activities       ActivityLog[]

  @@index([clientId])
  @@index([programId])
  @@map("projects")
}

model ProjectResponsible {
  projectId String  @map("project_id")
  userId    String  @map("user_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_responsibles")
}

model StateTransition {
  id        String       @id @default(cuid())
  projectId String       @map("project_id")
  fromState ProjectState @map("from_state")
  toState   ProjectState @map("to_state")
  byUserId  String?      @map("by_user_id")
  at        DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  byUser  User?   @relation(fields: [byUserId], references: [id])

  @@index([projectId])
  @@map("state_transitions")
}

// ─── Taxonomia e Checklist (Épicos D/E) ──────────────────────────────────
model DocumentType {
  id           String          @id @default(cuid())
  key          String          @unique
  name         String
  purpose      String?
  appliesTo    String[]        @map("applies_to") // códigos de programa ou ["ALL"]
  targetFolder String          @map("target_folder")
  hasExpiry    Boolean         @default(false) @map("has_expiry")
  checklist    ChecklistItem[]
  documents    Document[]

  @@map("document_types")
}

model ChecklistItem {
  id                String          @id @default(cuid())
  projectId         String          @map("project_id")
  documentTypeId    String          @map("document_type_id")
  responsibleUserId String?         @map("responsible_user_id")
  status            ChecklistStatus @default(EM_FALTA)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentType DocumentType @relation(fields: [documentTypeId], references: [id])
  responsible  User?        @relation("ChecklistResponsible", fields: [responsibleUserId], references: [id])
  documents    Document[]

  @@unique([projectId, documentTypeId])
  @@index([projectId])
  @@map("checklist_items")
}

model Document {
  id               String        @id @default(cuid())
  projectId        String        @map("project_id")
  checklistItemId  String?       @map("checklist_item_id")
  documentTypeId   String?       @map("document_type_id")
  originalFilename String        @map("original_filename")
  storedFilename   String?       @map("stored_filename")
  workdriveFileId  String?       @map("workdrive_file_id")
  workdriveUrl     String?       @map("workdrive_url")
  confidence       DocConfidence @default(ALTA)
  parentDocumentId String?       @map("parent_document_id")
  status           String        @default("recebido")
  createdAt        DateTime      @default(now()) @map("created_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checklistItem ChecklistItem? @relation(fields: [checklistItemId], references: [id])
  documentType  DocumentType?  @relation(fields: [documentTypeId], references: [id])
  parent        Document?      @relation("DocumentSplits", fields: [parentDocumentId], references: [id])
  parts         Document[]     @relation("DocumentSplits")

  @@index([projectId])
  @@map("documents")
}

// ─── Épico D/F — Recolha e Seguimento ────────────────────────────────────
model CollectionLink {
  id        String               @id @default(cuid())
  projectId String               @map("project_id")
  token     String               @unique
  expiresAt DateTime             @map("expires_at")
  usedAt    DateTime?            @map("used_at")
  createdById String?            @map("created_by_id")
  status    CollectionLinkStatus @default(ATIVO)
  createdAt DateTime             @default(now()) @map("created_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?      @relation(fields: [createdById], references: [id])
  reminders Reminder[]

  @@index([projectId])
  @@map("collection_links")
}

model Reminder {
  id               String         @id @default(cuid())
  projectId        String         @map("project_id")
  collectionLinkId String?        @map("collection_link_id")
  attemptNo        Int            @map("attempt_no")
  scheduledFor     DateTime       @map("scheduled_for")
  sentAt           DateTime?      @map("sent_at")
  status           ReminderStatus @default(AGENDADO)

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collectionLink CollectionLink? @relation(fields: [collectionLinkId], references: [id])

  @@index([projectId])
  @@map("reminders")
}

// ─── Prazos e Tarefas (ecrãs do protótipo) ───────────────────────────────
model Deadline {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  label     String
  dueDate   DateTime @map("due_date")
  portal    String?
  status    String   @default("pendente")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("deadlines")
}

model Task {
  id         String    @id @default(cuid())
  projectId  String?   @map("project_id")
  title      String
  assigneeId String?   @map("assignee_id")
  dueDate    DateTime? @map("due_date")
  priority   String    @default("Normal")
  status     String    @default("Pendente")
  category   String?

  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee User?    @relation(fields: [assigneeId], references: [id])

  @@map("tasks")
}

// ─── Épico G — A0 Diagnóstico ────────────────────────────────────────────
model Diagnostic {
  id               String   @id @default(cuid())
  projectId        String   @map("project_id")
  programId        String   @map("program_id")
  score            Int?
  criteriaBreakdown Json?   @map("criteria_breakdown")
  riskPoints       Json?    @map("risk_points")
  decision         String?
  decidedByUserId  String?  @map("decided_by_user_id")
  reportUrl        String?  @map("report_url")
  createdAt        DateTime @default(now()) @map("created_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  program   Program @relation(fields: [programId], references: [id])
  decidedBy User?   @relation(fields: [decidedByUserId], references: [id])

  @@index([projectId])
  @@map("diagnostics")
}

model Aviso {
  id        String    @id @default(cuid())
  programId String?   @map("program_id")
  measure   String
  openDate  DateTime? @map("open_date")
  closeDate DateTime? @map("close_date")
  dotacao   Decimal?  @db.Decimal(14, 2)
  url       String?

  program Program? @relation(fields: [programId], references: [id])

  @@map("avisos")
}

model MeritGrid {
  id          String  @id @default(cuid())
  programId   String  @map("program_id")
  name        String
  // pesos/critérios A/B/C/D (fórmula MP=0,2A+0,3B+0,1C+0,4D) + variantes regionais
  criteria    Json
  program     Program @relation(fields: [programId], references: [id])

  @@map("merit_grids")
}

// ─── Auditoria / Atividade ───────────────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  projectId   String?  @map("project_id")
  userId      String?  @map("user_id")
  type        String
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@map("activity_log")
}
