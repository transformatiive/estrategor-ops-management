// Estrategor — schema PostgreSQL (Semana 1).
// Fonte única do estado da aplicação (spec §8: nada de localStorage no front-end).
// Os enums espelham packages/shared/src/enums.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────
enum Role {
  GESTOR
  CONSULTOR
  ADMIN
}

enum MilestoneStatus {
  FEITO
  ATIVO
  POR_FAZER
}

enum ProjectState {
  A0
  A1
  A2
  A3
  A4
  B0
  B1
  B2
  ENCERRADO // estado terminal reversível "Não prosseguiu" (TRNSF-1044)
}

enum ChecklistStatus {
  EM_FALTA
  RECEBIDO
  EM_REVISAO
}

enum DocConfidence {
  ALTA
  BAIXA
}

enum ReminderStatus {
  AGENDADO
  ENVIADO
  ESCALADO
  FECHADO
}

enum CollectionLinkStatus {
  ATIVO
  USADO
  EXPIRADO
}

// Família do sistema de incentivos (TRNSF-942). 'qualificacao' previsto mas
// fora de âmbito v0.
enum CandFamily {
  inovacao_produtiva
  internacionalizacao
  qualificacao
}

// Estado da candidatura na máquina de estados A2/A3/A4.
enum CandStage {
  A2
  A3
  A4
}

// Proveniência de cada campo da candidatura (conceito central — TRNSF-942).
enum FieldOrigin {
  extraido // lido de documento do cliente (motor de extração)
  intake // fornecido pelo cliente no formulário de recolha
  gerado // produzido pelo motor de geração IA
  calculado // resultado de cálculo determinístico
  oficial_vies // dado oficial do VIES (Comissão Europeia) — nasce validado
  api_empresas // dado de API comercial de empresas (nif.pt) — por validar
  pre_diagnostico_ia // contexto/leitura por IA (Sonar+Sonnet) — por validar
}

enum FieldState {
  por_validar
  validado
  corrigido
}

// Método de extração de dados (TRNSF-952): determinístico = lido por código a
// partir de ficheiros estruturados; ia = extraído por modelo de linguagem.
enum ExtractMethod {
  deterministico
  ia
}

enum DocumentOrigin {
  CLIENTE
  MANUAL
}

// ─── Épico A — Acesso e Utilizadores ─────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  fullName     String   @map("full_name")
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(CONSULTOR)
  initials     String
  color        String   @default("green")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  responsibleFor   ProjectResponsible[]
  responsibleItems ChecklistItem[]      @relation("ChecklistResponsible")
  stateTransitions StateTransition[]
  createdLinks     CollectionLink[]
  assignedTasks    Task[]
  diagnostics      Diagnostic[]
  activities       ActivityLog[]
  sessions         Session[]
  validatedDocuments Document[]        @relation("ValidatedDocuments")
  validatedExtracoes Extracao[]        @relation("ValidatedExtracoes")
  validatedGeneratedFields GeneratedField[] @relation("ValidatedGeneratedFields")
  createdMeritGrids  MeritGrid[]       @relation("CreatedMeritGrids")

  @@map("users")
}

// Sessão server-side (TRNSF-934). Token aleatório guardado em cookie httpOnly;
// permite revogação imediata no logout e ao desativar o utilizador.
model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── Clientes e Programas ────────────────────────────────────────────────
model Client {
  id                String    @id @default(cuid())
  name              String
  nif               String?
  sector            String?
  workdriveFolderId String?   @map("workdrive_folder_id")
  crmDealId         String?   @unique @map("crm_deal_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  projects          Project[]

  @@map("clients")
}

model Program {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  projects    Project[]
  diagnostics Diagnostic[]
  avisos      Aviso[]

  @@map("programs")
}

// ─── Épico B — Base da Aplicação ─────────────────────────────────────────
model Project {
  id              String       @id @default(cuid())
  code            String       @unique
  title           String
  clientId        String       @map("client_id")
  programId       String       @map("program_id")
  state           ProjectState @default(A0)
  family          CandFamily?  // discriminador da família da candidatura (TRNSF-942)
  investmentTotal Decimal?     @map("investment_total") @db.Decimal(14, 2)
  incentiveValue  Decimal?     @map("incentive_value") @db.Decimal(14, 2)
  nextAction      String?      @map("next_action")
  measureLabel    String?      @map("measure_label")
  progress        Int          @default(0)
  crmDealId       String?      @unique @map("crm_deal_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  client           Client               @relation(fields: [clientId], references: [id])
  program          Program              @relation(fields: [programId], references: [id])
  responsibles     ProjectResponsible[]
  stateTransitions StateTransition[]
  checklistItems   ChecklistItem[]
  documents        Document[]
  collectionLinks  CollectionLink[]
  reminders        Reminder[]
  deadlines        Deadline[]
  milestones       Milestone[]
  folders          Folder[]
  tasks            Task[]
  diagnostics      Diagnostic[]
  activities       ActivityLog[]
  candidatura      Candidatura?
  preDiagnostico   PreDiagnostico?

  @@index([clientId])
  @@index([programId])
  @@map("projects")
}

// Pasta provisionada no WorkDrive por projecto (TRNSF-936). `path` é o caminho
// lógico relativo à raiz do projecto (ex.: "1-INCENTIVOS/Candidatura").
model Folder {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  path            String
  name            String
  workdriveId     String?  @map("workdrive_id")
  workdriveUrl    String?  @map("workdrive_url")
  parentPath      String?  @map("parent_path")
  isRoot          Boolean  @default(false) @map("is_root")
  createdAt       DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@index([projectId])
  @@map("folders")
}

model ProjectResponsible {
  projectId String  @map("project_id")
  userId    String  @map("user_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_responsibles")
}

model StateTransition {
  id        String       @id @default(cuid())
  projectId String       @map("project_id")
  fromState ProjectState @map("from_state")
  toState   ProjectState @map("to_state")
  byUserId  String?      @map("by_user_id")
  at        DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  byUser  User?   @relation(fields: [byUserId], references: [id])

  @@index([projectId])
  @@map("state_transitions")
}

// ─── Taxonomia e Checklist (Épicos D/E) ──────────────────────────────────
model DocumentType {
  id           String          @id @default(cuid())
  key          String          @unique
  name         String
  purpose      String?
  appliesTo    String[]        @map("applies_to") // códigos de programa ou ["ALL"]
  targetFolder String          @map("target_folder")
  hasExpiry    Boolean         @default(false) @map("has_expiry")
  checklist    ChecklistItem[]
  documents    Document[]
  proposedFor  Document[]      @relation("ProposedType")

  @@map("document_types")
}

model ChecklistItem {
  id                String          @id @default(cuid())
  projectId         String          @map("project_id")
  documentTypeId    String          @map("document_type_id")
  responsibleUserId String?         @map("responsible_user_id")
  status            ChecklistStatus @default(EM_FALTA)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentType DocumentType @relation(fields: [documentTypeId], references: [id])
  responsible  User?        @relation("ChecklistResponsible", fields: [responsibleUserId], references: [id])
  documents    Document[]

  @@unique([projectId, documentTypeId])
  @@index([projectId])
  @@map("checklist_items")
}

model Document {
  id               String         @id @default(cuid())
  projectId        String         @map("project_id")
  checklistItemId  String?        @map("checklist_item_id")
  documentTypeId   String?        @map("document_type_id")
  proposedTypeId   String?        @map("proposed_type_id")
  collectionLinkId String?        @map("collection_link_id")
  originalFilename String         @map("original_filename")
  storedFilename   String?        @map("stored_filename")
  workdriveFileId  String?        @map("workdrive_file_id")
  workdriveUrl     String?        @map("workdrive_url")
  mimeType         String?        @map("mime_type")
  sizeBytes        Int?           @map("size_bytes")
  origin           DocumentOrigin @default(MANUAL)
  confidence       DocConfidence  @default(ALTA)
  confidenceScore  Float?         @map("confidence_score")
  pageStart        Int?           @map("page_start")
  pageEnd          Int?           @map("page_end")
  parentDocumentId String?        @map("parent_document_id")
  status           String         @default("em_analise")
  validatedById    String?        @map("validated_by_id")
  validatedAt      DateTime?      @map("validated_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checklistItem  ChecklistItem?  @relation(fields: [checklistItemId], references: [id])
  documentType   DocumentType?   @relation(fields: [documentTypeId], references: [id])
  proposedType   DocumentType?   @relation("ProposedType", fields: [proposedTypeId], references: [id])
  collectionLink CollectionLink? @relation(fields: [collectionLinkId], references: [id])
  validatedBy    User?           @relation("ValidatedDocuments", fields: [validatedById], references: [id])
  parent         Document?       @relation("DocumentSplits", fields: [parentDocumentId], references: [id])
  parts          Document[]      @relation("DocumentSplits")
  extracao       Extracao?
  blob           DocumentBlob?

  @@index([projectId])
  @@index([collectionLinkId])
  @@index([status])
  @@map("documents")
}

// Armazenamento dos bytes do ficheiro na BD (TRNSF-1046) — por agora, até
// passarmos para o WorkDrive. Tabela à parte para não carregar os bytes nas
// listagens de documentos.
model DocumentBlob {
  id         String   @id @default(cuid())
  documentId String   @unique @map("document_id")
  bytes      Bytes
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_blobs")
}

// ─── Épico D/F — Recolha e Seguimento ────────────────────────────────────
// Pedido de recolha (spec §4 PedidoRecolha): link único, multi-uso até expirar,
// com os tipos de documento pedidos ao cliente (TRNSF-937).
model CollectionLink {
  id              String               @id @default(cuid())
  projectId       String               @map("project_id")
  token           String               @unique
  requestedKeys   String[]             @default([]) @map("requested_keys") // keys de DocumentType pedidas
  clientEmail     String?              @map("client_email")
  message         String?
  expiresAt       DateTime             @map("expires_at")
  usedAt          DateTime?            @map("used_at")
  createdById     String?              @map("created_by_id")
  status          CollectionLinkStatus @default(ATIVO)
  createdAt       DateTime             @default(now()) @map("created_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?      @relation(fields: [createdById], references: [id])
  reminders Reminder[]
  documents Document[]

  @@index([projectId])
  @@map("collection_links")
}

model Reminder {
  id               String         @id @default(cuid())
  projectId        String         @map("project_id")
  collectionLinkId String?        @map("collection_link_id")
  attemptNo        Int            @map("attempt_no")
  scheduledFor     DateTime       @map("scheduled_for")
  sentAt           DateTime?      @map("sent_at")
  status           ReminderStatus @default(AGENDADO)

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collectionLink CollectionLink? @relation(fields: [collectionLinkId], references: [id])

  @@index([projectId])
  @@map("reminders")
}

// ─── Prazos e Tarefas (ecrãs do protótipo) ───────────────────────────────
model Deadline {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  label     String
  dueDate   DateTime @map("due_date")
  portal    String?
  status    String   @default("pendente")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("deadlines")
}

// Timeline de marcos do projeto (drawer de detalhe — TRNSF-935).
model Milestone {
  id        String          @id @default(cuid())
  projectId String          @map("project_id")
  name      String
  date      String? // rótulo de data legível (ex.: "Mar 2024", "02 Jun 2026")
  status    MilestoneStatus @default(POR_FAZER)
  order     Int             @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("milestones")
}

model Task {
  id         String    @id @default(cuid())
  projectId  String?   @map("project_id")
  title      String
  assigneeId String?   @map("assignee_id")
  dueDate    DateTime? @map("due_date")
  priority   String    @default("Normal")
  status     String    @default("Pendente")
  category   String?

  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee User?    @relation(fields: [assigneeId], references: [id])

  @@map("tasks")
}

// ─── Épico G — A0 Diagnóstico ────────────────────────────────────────────
// Resultado do diagnóstico A0 de um projecto (condições de acesso + mérito).
model Diagnostic {
  id            String   @id @default(cuid())
  projectId     String   @unique @map("project_id")
  programId     String   @map("program_id")
  // condições de acesso avaliadas: [{ key, label, status: PASSA|FALHA|NA, note }]
  conditions    Json?
  // selecção por subcritério + breakdown calculado do mérito
  regiao        String? // região do investimento (resolve a matriz regional A.1)
  meritInputs   Json?    @map("merit_inputs")
  meritBreakdown Json?   @map("merit_breakdown")
  // Proposta de pontuação assistida por IA (TRNSF-1039) — SEPARADA da selecção
  // do consultor (meritInputs). A IA PROPÕE (estado por_validar); o consultor
  // revê, ajusta e guarda. Nunca inventa: sem evidência → proposta vazia + nota.
  // { selection: Record<subcrit, indice>, justificacoes: Record<subcrit, texto>, regiao }
  meritProposal Json?    @map("merit_proposal")
  meritProposalEstado String? @map("merit_proposal_estado") // por_validar | validado
  meritProposalNota   String? @map("merit_proposal_nota")
  mp            Decimal? @db.Decimal(5, 2)
  meritGridId   String?  @map("merit_grid_id")
  // TRNSF-1031: o aviso foi escolhido EXPLICITAMENTE pelo consultor (não pela
  // heurística). Sem isto não se conclui/avança o diagnóstico.
  avisoConfirmado Boolean @default(false) @map("aviso_confirmado")
  gridVersion   String?  @map("grid_version")
  // ELEGIVEL | NAO_ELEGIVEL | A_REVER | SEM_GRELHA | POR_INICIAR
  result        String   @default("POR_INICIAR")
  eligible      Boolean?
  // Justificação do encerramento "Não prosseguiu" (TRNSF-1044). Preenchida ao
  // encerrar um diagnóstico que não passa; limpa ao reabrir.
  encerradoMotivo String? @map("encerrado_motivo")
  decidedByUserId String? @map("decided_by_user_id")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  program   Program    @relation(fields: [programId], references: [id])
  meritGrid MeritGrid? @relation(fields: [meritGridId], references: [id])
  decidedBy User?      @relation(fields: [decidedByUserId], references: [id])

  @@index([projectId])
  @@map("diagnostics")
}

// ─── Pré-diagnóstico assistido por IA (TRNSF-967) ─────────────────────────
// Rascunho de diagnóstico produzido em segundo plano na criação do cliente,
// juntando fontes por fiabilidade (VIES oficial, API empresas comercial, IA
// contextual). NADA tem efeito sem validação humana. 1:1 com o projeto.
model PreDiagnostico {
  id        String   @id @default(cuid())
  projectId String   @unique @map("project_id")
  // pendente | concluido | falhou
  estado    String   @default("pendente")
  // estado por faixa: pendente | ok | falhou | sem_chave
  estadoVies        String @default("pendente") @map("estado_vies")
  estadoApiEmpresas String @default("pendente") @map("estado_api_empresas")
  estadoSonar       String @default("pendente") @map("estado_sonar")
  estadoSonnet      String @default("pendente") @map("estado_sonnet")
  // Passo automático da elegibilidade do aviso (TRNSF-1034): importa do PDF do
  // aviso escolhido como parte do progresso. pendente|ok|falhou|indisponivel.
  estadoElegibilidade String @default("pendente") @map("estado_elegibilidade")
  elegibilidadeDetalhe String? @map("elegibilidade_detalhe")
  // [{ key, label, value, origem, estado, fonte }] — campos com proveniência
  campos            Json?
  // [{ item, nota }] — checklist "a confirmar oficialmente" (a IA não garante)
  checklistAConfirmar Json? @map("checklist_a_confirmar")
  // auditoria: respostas em bruto e fontes
  fontesSonar       Json?  @map("fontes_sonar")
  brutoVies         Json?  @map("bruto_vies")
  brutoApiEmpresas  Json?  @map("bruto_api_empresas")
  executadoEm       DateTime? @map("executado_em")
  createdAt         DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("pre_diagnosticos")
}

model Aviso {
  id        String    @id @default(cuid())
  programId String?   @map("program_id")
  measure   String
  openDate  DateTime? @map("open_date")
  closeDate DateTime? @map("close_date")
  dotacao   Decimal?  @db.Decimal(14, 2)
  url       String?

  program Program? @relation(fields: [programId], references: [id])

  @@map("avisos")
}

// Grelha de mérito (TRNSF-941) — DADOS, nunca código. Identificada por
// programa·medida·codigo_aviso·regiao·versao. `grid` guarda o JSON completo do
// referencial (escala, fórmula, critérios/subcritérios). `accessConditions`
// guarda as condições de acesso (§7.1) do aviso, também como dados.
model MeritGrid {
  id               String   @id @default(cuid())
  programCode      String   @map("program_code")
  measure          String
  codigoAviso      String   @map("codigo_aviso")
  regiao           String? // nulo quando o referencial não varia por região
  versao           String
  fonteUrl         String?  @map("fonte_url")
  mpMinimo         Decimal? @map("mp_minimo") @db.Decimal(5, 2)
  minimoPorCriterio Decimal? @map("minimo_por_criterio") @db.Decimal(5, 2)
  formulaMp        String?  @map("formula_mp")
  grid             Json
  accessConditions Json?    @map("access_conditions")
  // Elegibilidade estruturada do aviso (TRNSF-1030): CAE elegíveis, regiões NUTS,
  // baixa densidade, naturezas + estado (por_validar|validado). Vem do PDF do
  // aviso, validada por admin. Sem isto, não há "Provável PASSA/FALHA".
  eligibilidade    Json?    @map("eligibilidade")
  extracted        Boolean  @default(true) // false = rascunho/por publicar; true = publicado (visível aos consultores)
  createdByUserId  String?  @map("created_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @default(now()) @map("updated_at")

  diagnostics Diagnostic[]
  createdBy   User?        @relation("CreatedMeritGrids", fields: [createdByUserId], references: [id])

  @@unique([programCode, measure, codigoAviso, regiao, versao])
  @@map("merit_grids")
}

// ─── Auditoria / Atividade ───────────────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  projectId   String?  @map("project_id")
  userId      String?  @map("user_id")
  type        String
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@map("activity_log")
}

// ─── Candidatura (TRNSF-942 · núcleo) ────────────────────────────────────
// Cabeçalho da candidatura PT2030. Uma por projecto. Ramifica pela família.
model Candidatura {
  id              String     @id @default(cuid())
  projectId       String     @unique @map("project_id")
  family          CandFamily
  codigoAviso     String?    @map("codigo_aviso")
  medida          String?
  codigoProjetoSgo String?   @map("codigo_projeto_sgo")
  stage           CandStage  @default(A2)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fields          CandField[]
  extracoes       Extracao[]
  generatedFields GeneratedField[]
  verificacoes    Verificacao[]

  @@map("candidaturas")
}

// Armazém genérico de campos da candidatura com proveniência por campo.
// Cada campo é identificado por (candidatura, secção, chave) e regista o seu
// valor + origem + estado de validação. As secções comuns (cand_*) e as
// específicas de família são definidas no catálogo em @estrategor/shared; as
// tabelas tipadas específicas entram nos tickets de cada secção.
model CandField {
  id            String      @id @default(cuid())
  candidaturaId String      @map("candidatura_id")
  section       String // ex.: "beneficiario", "declaracoes" (chave da secção comum)
  key           String // ex.: "nif", "nome", "cae_principal"
  // valor guardado como JSON para suportar texto, número, datas e linhas de tabela
  value         Json?
  origin        FieldOrigin
  state         FieldState  @default(por_validar)
  // proveniência auxiliar: documento de origem (extração), nota de geração, etc.
  sourceRef     String?     @map("source_ref")
  updatedById   String?     @map("updated_by_id")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  candidatura Candidatura @relation(fields: [candidaturaId], references: [id], onDelete: Cascade)

  @@unique([candidaturaId, section, key])
  @@index([candidaturaId])
  @@index([candidaturaId, section])
  @@map("cand_fields")
}

// ─── Extração de dados (TRNSF-952) ───────────────────────────────────────
// Ponte entre os documentos arquivados (TRNSF-938) e os campos da candidatura
// (TRNSF-942). Uma extração por documento; os campos extraídos ficam em
// `campos_extraidos` (JSON) e entram na fila de validação. Só ao confirmar é
// que são escritos nos CandField com origem='extraido'.
model Extracao {
  id              String        @id @default(cuid())
  documentId      String        @unique @map("document_id")
  candidaturaId   String        @map("candidatura_id")
  tipoDocumento   String        @map("tipo_documento")
  metodo          ExtractMethod
  // confiança global (0..1); null nos determinísticos (leitura exata)
  confianca       Float?
  // [{ section, key, label, value, confianca }]
  camposExtraidos Json          @map("campos_extraidos")
  // nota do extractor (ex.: "IA indisponível", "sem estrutura reconhecida")
  nota            String?
  estado          FieldState    @default(por_validar)
  validatedById   String?       @map("validated_by_id")
  validatedAt     DateTime?     @map("validated_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  document    Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  candidatura Candidatura @relation(fields: [candidaturaId], references: [id], onDelete: Cascade)
  validatedBy User?       @relation("ValidatedExtracoes", fields: [validatedById], references: [id])

  @@index([candidaturaId])
  @@map("extracoes")
}

// ─── Geração IA de texto (TRNSF-943) ─────────────────────────────────────
// Minutas de texto livre geradas por IA para o consultor refinar. Cada geração
// preenche um CandField (origem='gerado'). Versionado: cada geração/edição é
// uma linha nova (versao crescente). doc_type é validado contra o catálogo em
// @estrategor/shared (dados, não enum de BD) para se acrescentarem campos sem
// migração.
model GeneratedField {
  id            String     @id @default(cuid())
  candidaturaId String     @map("candidatura_id")
  docType       String     @map("doc_type")
  family        CandFamily
  versao        Int        @default(1)
  estado        FieldState @default(por_validar)
  conteudo      String
  // {documento_ids, intake_keys, grelha_id, ...} — proveniência da geração
  dataSources   Json?      @map("data_sources")
  charLimit     Int        @map("char_limit")
  charCount     Int        @map("char_count")
  geradoEm      DateTime   @default(now()) @map("gerado_em")
  validatedById String?    @map("validated_by_id")
  validatedAt   DateTime?  @map("validated_at")

  candidatura Candidatura @relation(fields: [candidaturaId], references: [id], onDelete: Cascade)
  validatedBy User?       @relation("ValidatedGeneratedFields", fields: [validatedById], references: [id])

  @@index([candidaturaId])
  @@index([candidaturaId, docType])
  @@map("generated_documents")
}

// ─── Verificador + Mérito (TRNSF-946) ────────────────────────────────────
// Resultado da verificação da candidatura nos três eixos (formulário, mérito,
// coerência) + o mérito previsto (MP) calculado deterministicamente a partir da
// grelha (TRNSF-941). Histórico: uma linha por execução de "Verificar".
model Verificacao {
  id               String      @id @default(cuid())
  candidaturaId    String      @map("candidatura_id")
  // conforme | nao_conforme | sem_grelha
  resultado        String
  naoConformidades Json        @map("nao_conformidades")
  mpPrevisto       Float?      @map("mp_previsto")
  mpPorCriterio    Json?       @map("mp_por_criterio")
  criadoEm         DateTime    @default(now()) @map("criado_em")

  candidatura Candidatura @relation(fields: [candidaturaId], references: [id], onDelete: Cascade)

  @@index([candidaturaId])
  @@map("verificacoes")
}

// ─── Catálogos / Rulebook (TRNSF-953) ────────────────────────────────────
// Listas de referência e regras como DADOS (não código). Lidas pelas secções,
// checklist e extração. Tabelas simples e versionáveis; trocar um catálogo não
// exige alterar código.

model CatalogoCae {
  codigo     String @id
  designacao String

  @@map("catalogo_cae")
}

model CatalogoGeo {
  id              String  @id @default(cuid())
  nuts2           String
  nuts3           String
  concelho        String
  freguesia       String?
  baixaDensidade  Boolean @default(false) @map("baixa_densidade")
  regiaoPrograma  String? @map("regiao_programa")

  @@index([nuts2])
  @@index([concelho])
  @@map("catalogo_geo")
}

model CatalogoPais {
  codigo String @id
  nome   String

  @@map("catalogo_pais")
}

model CatalogoRubricaSnc {
  id         String  @id @default(cuid())
  tipo       String // balanco | dr | financiamento
  codigo     String
  designacao String
  vidaUtil   Int?    @map("vida_util")

  @@unique([tipo, codigo])
  @@index([tipo])
  @@map("catalogo_rubrica_snc")
}

model CatalogoCategoriaCusto {
  id         String     @id @default(cuid())
  familia    CandFamily
  codigo     String
  designacao String

  @@unique([familia, codigo])
  @@map("catalogo_categoria_custo")
}

model CatalogoIndicador {
  codigo     String  @id
  designacao String
  unidade    String?
  dominio    String?

  @@map("catalogo_indicador")
}

model CatalogoDominioIntl {
  numero     Int    @id
  designacao String

  @@map("catalogo_dominio_intl")
}

model CatalogoTipoDocumento {
  codigo           String @id
  designacao       String
  subpastaWorkdrive String @map("subpasta_workdrive")

  @@map("catalogo_tipo_documento")
}

model CatalogoAnexo {
  id          String     @id @default(cuid())
  familia     CandFamily
  nivel       String // transversal | tipologia | condicional
  codigo      String
  designacao  String
  condicao    String?
  obrigatorio Boolean    @default(true)

  @@unique([familia, codigo])
  @@index([familia, nivel])
  @@map("catalogo_anexo")
}
