// Estrategor — schema PostgreSQL (Semana 1).
// Fonte única do estado da aplicação (spec §8: nada de localStorage no front-end).
// Os enums espelham packages/shared/src/enums.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────
enum Role {
  GESTOR
  CONSULTOR
  ADMIN
}

enum MilestoneStatus {
  FEITO
  ATIVO
  POR_FAZER
}

enum ProjectState {
  A0
  A1
  A2
  A3
  A4
  B0
  B1
  B2
}

enum ChecklistStatus {
  EM_FALTA
  RECEBIDO
  EM_REVISAO
}

enum DocConfidence {
  ALTA
  BAIXA
}

enum ReminderStatus {
  AGENDADO
  ENVIADO
  ESCALADO
  FECHADO
}

enum CollectionLinkStatus {
  ATIVO
  USADO
  EXPIRADO
}

enum DocumentOrigin {
  CLIENTE
  MANUAL
}

// ─── Épico A — Acesso e Utilizadores ─────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  fullName     String   @map("full_name")
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(CONSULTOR)
  initials     String
  color        String   @default("green")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  responsibleFor   ProjectResponsible[]
  responsibleItems ChecklistItem[]      @relation("ChecklistResponsible")
  stateTransitions StateTransition[]
  createdLinks     CollectionLink[]
  assignedTasks    Task[]
  diagnostics      Diagnostic[]
  activities       ActivityLog[]
  sessions         Session[]
  validatedDocuments Document[]        @relation("ValidatedDocuments")

  @@map("users")
}

// Sessão server-side (TRNSF-934). Token aleatório guardado em cookie httpOnly;
// permite revogação imediata no logout e ao desativar o utilizador.
model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── Clientes e Programas ────────────────────────────────────────────────
model Client {
  id                String    @id @default(cuid())
  name              String
  nif               String?
  sector            String?
  workdriveFolderId String?   @map("workdrive_folder_id")
  crmDealId         String?   @unique @map("crm_deal_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  projects          Project[]

  @@map("clients")
}

model Program {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  projects    Project[]
  diagnostics Diagnostic[]
  avisos      Aviso[]

  @@map("programs")
}

// ─── Épico B — Base da Aplicação ─────────────────────────────────────────
model Project {
  id              String       @id @default(cuid())
  code            String       @unique
  title           String
  clientId        String       @map("client_id")
  programId       String       @map("program_id")
  state           ProjectState @default(A0)
  investmentTotal Decimal?     @map("investment_total") @db.Decimal(14, 2)
  incentiveValue  Decimal?     @map("incentive_value") @db.Decimal(14, 2)
  nextAction      String?      @map("next_action")
  measureLabel    String?      @map("measure_label")
  progress        Int          @default(0)
  crmDealId       String?      @unique @map("crm_deal_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  client           Client               @relation(fields: [clientId], references: [id])
  program          Program              @relation(fields: [programId], references: [id])
  responsibles     ProjectResponsible[]
  stateTransitions StateTransition[]
  checklistItems   ChecklistItem[]
  documents        Document[]
  collectionLinks  CollectionLink[]
  reminders        Reminder[]
  deadlines        Deadline[]
  milestones       Milestone[]
  folders          Folder[]
  tasks            Task[]
  diagnostics      Diagnostic[]
  activities       ActivityLog[]

  @@index([clientId])
  @@index([programId])
  @@map("projects")
}

// Pasta provisionada no WorkDrive por projecto (TRNSF-936). `path` é o caminho
// lógico relativo à raiz do projecto (ex.: "1-INCENTIVOS/Candidatura").
model Folder {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  path            String
  name            String
  workdriveId     String?  @map("workdrive_id")
  workdriveUrl    String?  @map("workdrive_url")
  parentPath      String?  @map("parent_path")
  isRoot          Boolean  @default(false) @map("is_root")
  createdAt       DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@index([projectId])
  @@map("folders")
}

model ProjectResponsible {
  projectId String  @map("project_id")
  userId    String  @map("user_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_responsibles")
}

model StateTransition {
  id        String       @id @default(cuid())
  projectId String       @map("project_id")
  fromState ProjectState @map("from_state")
  toState   ProjectState @map("to_state")
  byUserId  String?      @map("by_user_id")
  at        DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  byUser  User?   @relation(fields: [byUserId], references: [id])

  @@index([projectId])
  @@map("state_transitions")
}

// ─── Taxonomia e Checklist (Épicos D/E) ──────────────────────────────────
model DocumentType {
  id           String          @id @default(cuid())
  key          String          @unique
  name         String
  purpose      String?
  appliesTo    String[]        @map("applies_to") // códigos de programa ou ["ALL"]
  targetFolder String          @map("target_folder")
  hasExpiry    Boolean         @default(false) @map("has_expiry")
  checklist    ChecklistItem[]
  documents    Document[]
  proposedFor  Document[]      @relation("ProposedType")

  @@map("document_types")
}

model ChecklistItem {
  id                String          @id @default(cuid())
  projectId         String          @map("project_id")
  documentTypeId    String          @map("document_type_id")
  responsibleUserId String?         @map("responsible_user_id")
  status            ChecklistStatus @default(EM_FALTA)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentType DocumentType @relation(fields: [documentTypeId], references: [id])
  responsible  User?        @relation("ChecklistResponsible", fields: [responsibleUserId], references: [id])
  documents    Document[]

  @@unique([projectId, documentTypeId])
  @@index([projectId])
  @@map("checklist_items")
}

model Document {
  id               String         @id @default(cuid())
  projectId        String         @map("project_id")
  checklistItemId  String?        @map("checklist_item_id")
  documentTypeId   String?        @map("document_type_id")
  proposedTypeId   String?        @map("proposed_type_id")
  collectionLinkId String?        @map("collection_link_id")
  originalFilename String         @map("original_filename")
  storedFilename   String?        @map("stored_filename")
  workdriveFileId  String?        @map("workdrive_file_id")
  workdriveUrl     String?        @map("workdrive_url")
  mimeType         String?        @map("mime_type")
  sizeBytes        Int?           @map("size_bytes")
  origin           DocumentOrigin @default(MANUAL)
  confidence       DocConfidence  @default(ALTA)
  confidenceScore  Float?         @map("confidence_score")
  pageStart        Int?           @map("page_start")
  pageEnd          Int?           @map("page_end")
  parentDocumentId String?        @map("parent_document_id")
  status           String         @default("em_analise")
  validatedById    String?        @map("validated_by_id")
  validatedAt      DateTime?      @map("validated_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checklistItem  ChecklistItem?  @relation(fields: [checklistItemId], references: [id])
  documentType   DocumentType?   @relation(fields: [documentTypeId], references: [id])
  proposedType   DocumentType?   @relation("ProposedType", fields: [proposedTypeId], references: [id])
  collectionLink CollectionLink? @relation(fields: [collectionLinkId], references: [id])
  validatedBy    User?           @relation("ValidatedDocuments", fields: [validatedById], references: [id])
  parent         Document?       @relation("DocumentSplits", fields: [parentDocumentId], references: [id])
  parts          Document[]      @relation("DocumentSplits")

  @@index([projectId])
  @@index([collectionLinkId])
  @@index([status])
  @@map("documents")
}

// ─── Épico D/F — Recolha e Seguimento ────────────────────────────────────
// Pedido de recolha (spec §4 PedidoRecolha): link único, multi-uso até expirar,
// com os tipos de documento pedidos ao cliente (TRNSF-937).
model CollectionLink {
  id              String               @id @default(cuid())
  projectId       String               @map("project_id")
  token           String               @unique
  requestedKeys   String[]             @default([]) @map("requested_keys") // keys de DocumentType pedidas
  clientEmail     String?              @map("client_email")
  message         String?
  expiresAt       DateTime             @map("expires_at")
  usedAt          DateTime?            @map("used_at")
  createdById     String?              @map("created_by_id")
  status          CollectionLinkStatus @default(ATIVO)
  createdAt       DateTime             @default(now()) @map("created_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?      @relation(fields: [createdById], references: [id])
  reminders Reminder[]
  documents Document[]

  @@index([projectId])
  @@map("collection_links")
}

model Reminder {
  id               String         @id @default(cuid())
  projectId        String         @map("project_id")
  collectionLinkId String?        @map("collection_link_id")
  attemptNo        Int            @map("attempt_no")
  scheduledFor     DateTime       @map("scheduled_for")
  sentAt           DateTime?      @map("sent_at")
  status           ReminderStatus @default(AGENDADO)

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collectionLink CollectionLink? @relation(fields: [collectionLinkId], references: [id])

  @@index([projectId])
  @@map("reminders")
}

// ─── Prazos e Tarefas (ecrãs do protótipo) ───────────────────────────────
model Deadline {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  label     String
  dueDate   DateTime @map("due_date")
  portal    String?
  status    String   @default("pendente")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("deadlines")
}

// Timeline de marcos do projeto (drawer de detalhe — TRNSF-935).
model Milestone {
  id        String          @id @default(cuid())
  projectId String          @map("project_id")
  name      String
  date      String? // rótulo de data legível (ex.: "Mar 2024", "02 Jun 2026")
  status    MilestoneStatus @default(POR_FAZER)
  order     Int             @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("milestones")
}

model Task {
  id         String    @id @default(cuid())
  projectId  String?   @map("project_id")
  title      String
  assigneeId String?   @map("assignee_id")
  dueDate    DateTime? @map("due_date")
  priority   String    @default("Normal")
  status     String    @default("Pendente")
  category   String?

  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee User?    @relation(fields: [assigneeId], references: [id])

  @@map("tasks")
}

// ─── Épico G — A0 Diagnóstico ────────────────────────────────────────────
// Resultado do diagnóstico A0 de um projecto (condições de acesso + mérito).
model Diagnostic {
  id            String   @id @default(cuid())
  projectId     String   @unique @map("project_id")
  programId     String   @map("program_id")
  // condições de acesso avaliadas: [{ key, label, status: PASSA|FALHA|NA, note }]
  conditions    Json?
  // selecção por subcritério + breakdown calculado do mérito
  regiao        String? // região do investimento (resolve a matriz regional A.1)
  meritInputs   Json?    @map("merit_inputs")
  meritBreakdown Json?   @map("merit_breakdown")
  mp            Decimal? @db.Decimal(5, 2)
  meritGridId   String?  @map("merit_grid_id")
  gridVersion   String?  @map("grid_version")
  // ELEGIVEL | NAO_ELEGIVEL | A_REVER | SEM_GRELHA | POR_INICIAR
  result        String   @default("POR_INICIAR")
  eligible      Boolean?
  decidedByUserId String? @map("decided_by_user_id")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  program   Program    @relation(fields: [programId], references: [id])
  meritGrid MeritGrid? @relation(fields: [meritGridId], references: [id])
  decidedBy User?      @relation(fields: [decidedByUserId], references: [id])

  @@index([projectId])
  @@map("diagnostics")
}

model Aviso {
  id        String    @id @default(cuid())
  programId String?   @map("program_id")
  measure   String
  openDate  DateTime? @map("open_date")
  closeDate DateTime? @map("close_date")
  dotacao   Decimal?  @db.Decimal(14, 2)
  url       String?

  program Program? @relation(fields: [programId], references: [id])

  @@map("avisos")
}

// Grelha de mérito (TRNSF-941) — DADOS, nunca código. Identificada por
// programa·medida·codigo_aviso·regiao·versao. `grid` guarda o JSON completo do
// referencial (escala, fórmula, critérios/subcritérios). `accessConditions`
// guarda as condições de acesso (§7.1) do aviso, também como dados.
model MeritGrid {
  id               String   @id @default(cuid())
  programCode      String   @map("program_code")
  measure          String
  codigoAviso      String   @map("codigo_aviso")
  regiao           String? // nulo quando o referencial não varia por região
  versao           String
  fonteUrl         String?  @map("fonte_url")
  mpMinimo         Decimal? @map("mp_minimo") @db.Decimal(5, 2)
  minimoPorCriterio Decimal? @map("minimo_por_criterio") @db.Decimal(5, 2)
  formulaMp        String?  @map("formula_mp")
  grid             Json
  accessConditions Json?    @map("access_conditions")
  extracted        Boolean  @default(true) // false = ainda só registo (a extrair)
  createdAt        DateTime @default(now()) @map("created_at")

  diagnostics Diagnostic[]

  @@unique([programCode, measure, codigoAviso, regiao, versao])
  @@map("merit_grids")
}

// ─── Auditoria / Atividade ───────────────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  projectId   String?  @map("project_id")
  userId      String?  @map("user_id")
  type        String
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@map("activity_log")
}
