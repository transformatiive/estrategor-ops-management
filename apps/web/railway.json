{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @estrategor/web build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @estrategor/web preview",
    "restartPolicyType": "ON_FAILURE"
  }
}
