# ─── API ───────────────────────────────────────────────────────────────
# PostgreSQL (Railway injeta DATABASE_URL automaticamente em produção)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/estrategor?schema=public"

# Porta da API (Railway injeta PORT)
PORT=3001
NODE_ENV=development

# Segredo para assinar a sessão/JWT (Épico A) — gerar com: openssl rand -hex 32
SESSION_SECRET="dev-only-change-me"

# Token partilhado que o n8n usa nos callbacks para a API (Épicos E/F)
N8N_CALLBACK_TOKEN="dev-only-change-me"

# Bootstrap do primeiro gestor/admin (TRNSF-934). Em produção definir no Railway.
# Se não existir nenhum gestor/admin activo, este utilizador é criado/promovido no arranque.
# ADMIN_EMAIL="admin@estrategor.pt"
# ADMIN_PASSWORD="trocar-isto-em-producao"

# Validade da sessão (dias)
SESSION_TTL_DAYS=7

# Palavra-passe partilhada dos utilizadores de demonstração no seed
SEED_DEMO_PASSWORD="estrategor2026"

# Origem permitida para CORS (a SPA web)
WEB_ORIGIN="http://localhost:5173"

# ─── Zoho WorkDrive (TRNSF-936/937) ──────────────────────────────────────
# Sem estas variáveis, o adaptador corre em modo "stub" (sem rede) — dev/CI/demo.
# WORKDRIVE_ROOT_FOLDER_ID="..."
# WORKDRIVE_ACCESS_TOKEN="..."
# WORKDRIVE_REFRESH_TOKEN="..."
# WORKDRIVE_CLIENT_ID="..."
# WORKDRIVE_CLIENT_SECRET="..."
# Diretório onde o stub guarda os ficheiros carregados pelo cliente (dev/CI/demo).
WORKDRIVE_STUB_DIR="/tmp/estrategor-workdrive"
# Tamanho máximo por ficheiro carregado pelo cliente (bytes). Default 25 MB.
UPLOAD_MAX_BYTES=26214400

# ─── Classificação por IA (TRNSF-938) ────────────────────────────────────
# Sem OPENROUTER_API_KEY, a classificação corre em modo stub determinístico
# (dev/CI/demo). Em produção definir a chave no Railway — NUNCA no repositório.
# OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"
OPENROUTER_BASE="https://openrouter.ai/api/v1"

# ─── Outras integrações (usadas pelo n8n, aqui só para referência) ───────
# CLAUDE_API_KEY=...
# CRM_WEBHOOK_TOKEN=...

# ─── WEB ───────────────────────────────────────────────────────────────
# URL base da API que a SPA consome
VITE_API_URL="http://localhost:3001"
