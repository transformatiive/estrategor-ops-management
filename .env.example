# ─── API ───────────────────────────────────────────────────────────────
# PostgreSQL (Railway injeta DATABASE_URL automaticamente em produção)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/estrategor?schema=public"

# Porta da API (Railway injeta PORT)
PORT=3001
NODE_ENV=development

# Segredo para assinar a sessão/JWT (Épico A) — gerar com: openssl rand -hex 32
SESSION_SECRET="dev-only-change-me"

# Token partilhado que o n8n usa nos callbacks para a API (Épicos E/F)
N8N_CALLBACK_TOKEN="dev-only-change-me"

# Bootstrap do primeiro gestor/admin (TRNSF-934). Em produção definir no Railway.
# Se não existir nenhum gestor/admin activo, este utilizador é criado/promovido no arranque.
# ADMIN_EMAIL="admin@estrategor.pt"
# ADMIN_PASSWORD="trocar-isto-em-producao"

# Validade da sessão (dias)
SESSION_TTL_DAYS=7

# Palavra-passe partilhada dos utilizadores de demonstração no seed
SEED_DEMO_PASSWORD="estrategor2026"

# Origem permitida para CORS (a SPA web)
WEB_ORIGIN="http://localhost:5173"

# ─── Integrações (usadas pelo n8n, aqui só para referência) ──────────────
# CLAUDE_API_KEY=...
# WORKDRIVE_CLIENT_ID=...
# WORKDRIVE_CLIENT_SECRET=...
# WORKDRIVE_REFRESH_TOKEN=...
# CRM_WEBHOOK_TOKEN=...

# ─── WEB ───────────────────────────────────────────────────────────────
# URL base da API que a SPA consome
VITE_API_URL="http://localhost:3001"
