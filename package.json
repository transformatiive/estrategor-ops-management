{
  "name": "estrategor-ops-management",
  "version": "0.1.0",
  "private": true,
  "description": "Estrategor — Plataforma Operacional para gestão de candidaturas a fundos (PT2030).",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "prisma:generate": "pnpm --filter @estrategor/api prisma:generate",
    "prisma:migrate": "pnpm --filter @estrategor/api prisma:migrate",
    "prisma:seed": "pnpm --filter @estrategor/api prisma:seed",
    "db:validate": "pnpm --filter @estrategor/api prisma:validate"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma"]
  }
}
